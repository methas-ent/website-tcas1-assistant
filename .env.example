# Copy to `.env` and customize. Do not commit real secrets.

# Prisma / SQLite for local dev.
DATABASE_URL="file:./dev.db"

# Admin seed account. The seed script hashes ADMIN_PASSWORD before storing it.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-long-local-admin-password"

ADMIN_NAME="VDO Admin"

# Demo progress fallback for current catalog/player queries until auth is wired.
DEMO_USER_KEY="demo-user"

# Optional demo student for local QA seed. The seed hashes DEMO_STUDENT_PASSWORD.
DEMO_STUDENT_EMAIL="student@example.com"
DEMO_STUDENT_PASSWORD="replace-with-a-long-local-student-password"
DEMO_STUDENT_NAME="Demo Student"

# Secret used by future auth/session code. Must be long and random outside dev.
AUTH_SESSION_SECRET="replace-me-with-a-long-random-string"

# Secret used to sign short-lived playback tokens (HMAC).
# MUST be a long, random string in any non-local environment.
# Owned by the secure-playback agent.
PLAYBACK_SECRET="replace-me-with-a-long-random-string"
PLAYBACK_TOKEN_TTL_SECONDS="120"

# Local dev video upload storage. Keep this outside source code and git.
LOCAL_VIDEO_STORAGE_DIR=".local/uploads/videos"
VIDEO_UPLOAD_MAX_BYTES="524288000"

# Local dev payment slip upload storage. Keep this outside source code and git.
LOCAL_PAYMENT_SLIP_STORAGE_DIR=".local/uploads/payment-slips"
PAYMENT_SLIP_MAX_BYTES="10485760"

# Local dev public cover image upload storage for course/package covers.
LOCAL_COVER_IMAGE_STORAGE_DIR=".local/uploads/covers"
COVER_IMAGE_MAX_BYTES="5242880"

# Expo mobile app. Use your LAN IP instead of localhost when testing on a real device.
EXPO_PUBLIC_API_BASE_URL="http://localhost:3001"
